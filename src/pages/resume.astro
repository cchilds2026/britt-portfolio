---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import RevealScript from "../components/RevealScript.astro";
---

<BaseLayout title="Resume — Brittany Childs" description="Resume and experience overview for Brittany Childs">
  <Nav />

  <main>
    <section class="section about-grid">
      <div class="reveal about-copy">
        <div class="eyebrow">Resume</div>
        <h1 class="display" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
          Experience
        </h1>

        <p class="lead">
          My resume highlights 5 years of professional design experience, bringing together
          visual design, production awareness, and forward thinking for real educational contexts.
        </p>

        <p>
          For a fuller view of how I approach this work, you can also explore
          the case studies in the portfolio section.
        </p>

        <div class="process-strip about-stats">
          <div>
            <strong>Experience</strong>
            <p>5 years of professional design work in educational communications.</p>
          </div>
          <div>
            <strong>Strengths</strong>
            <p>Brand systems, publication design, large-format graphics, and accessibility-minded communication.</p>
          </div>
          <div>
            <strong>Recognition</strong>
            <p>Multiple design awards for visual communication and creative execution.</p>
          </div>
        </div>

        <div class= "button-row">
          <a class="button" href="/resume.pdf" target="_blank" rel="noopener noreferrer">
            Download Resume PDF
          </a>
          <a class="button" href="/work">
            View Selected Work
          </a>
        </div>
      </div>

      <div class="frame reveal">
        <img
          src="https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Resume+Preview+or+Detail"
          alt="Brittany Childs Resume Preview"
        />
      </div>
    </section>
  </main>

  <Footer />
  <RevealScript />
</BaseLayout>