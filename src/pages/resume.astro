---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Resume — Brittany Childs" description="Resume page">
  <Nav />

  <main>
    <section class="section">
      <div class="eyebrow">Resume</div>
      <h1 class="display" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">Resume</h1>
      <p class="lead">
        Download my current resume below.
      </p>
      <a class="button" href="/BC_Graphic Designer_Resume.pdf" target="_blank">Download Resume PDF</a>
    </section>
  </main>

  <Footer />
</BaseLayout>