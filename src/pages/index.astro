---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import RevealScript from "../components/RevealScript.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Brittany Childs — Portfolio"
  description="Graphic Designer with 5 years of experience creating branded communications for multiple school districts through CABOCES. Specializes in editorial, large-format, and institutional design within complex, deadline-driven production environments, with attention to clarity, usability, and inclusive communication. Currently leading development of CABOCES’ first comprehensive brand standards process through a multi-school identity project for Jamestown Area Schools."
>
  <Nav />

  <main>
    <section class="section hero-grid">
      <div class="reveal">
        <div class="eyebrow">Portfolio</div>
        <h1 class="display">Brittany Childs</h1>
        <p class="lead">
          Graphic Designer with 5 years of experience creating brand systems,
          editorial publications, and large-format communications for multiple school
          districts through CABOCES. My work is grounded in clarity, consistency,
          and thoughtful design for institutional audiences.
        </p>
        <a class="button" href="/work">View Selected Work</a>
      </div>

      <div class="frame reveal">
        <img
          src="https://placehold.co/1600x1000/e9e1d7/1f1b18?text=Featured+Visual"
          alt="Featured portfolio visual"
        />
      </div>
    </section>

    <section class="section feature-grid">
      <div class="reveal">
        <div class="eyebrow">Featured Project</div>
        <h2 class="project-title" style="font-size: 2rem;">
          Jamestown Area Schools Brand Book
        </h2>
        <p class="lead">
           A comprehensive multi-school identity standards project developed to
          strengthen consistency across district communications while also creating
          CABOCES’ first formal process for brand-book development.
        </p>
        <a class="button" href="/work/jamestown-brand-book">View Case Study</a>
      </div>

      <div class="frame reveal">
        <img
          src="https://placehold.co/1600x1000/e9e1d7/1f1b18?text=Brand+Book+Preview"
          alt="Jamestown brand book preview"
        />
      </div>
    </section>

    <section class="section">
      <div class="eyebrow">Selected Work</div>
      <div class="grid-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="section">
  <div class="process-strip reveal">
    <div>
      <strong>Multi-District Collaboration</strong>
      <p>
        Work developed across varied school stakeholders, audiences, and
        approval structures.
      </p>
    </div>
    <div>
      <strong>Brand Systems Development</strong>
      <p>
        Identity and standards work designed to support consistency over time.
      </p>
    </div>
    <div>
      <strong>Production-Aware Execution</strong>
      <p>
        Print and large-format design delivered with attention to scale,
        readability, and output quality.
      </p>
    </div>
  </div>
</section>
  </main>

  <Footer />
  <RevealScript />
</BaseLayout>