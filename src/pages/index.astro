---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import RevealScript from "../components/RevealScript.astro";
import ImageCarousel from "../components/ImageCarousel.astro";

const jamestownPreviewImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Jamestown+Cover",
    alt: "Jamestown brand book cover placeholder",
    caption: "A multi-school identity standards project and flagship brand systems case study."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Jamestown+Spread",
    alt: "Jamestown standards spread placeholder",
    caption: "Structured standards content designed for clarity, consistency, and long-term use."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Jamestown+Applications",
    alt: "Jamestown brand application placeholder",
    caption: "Application examples showing how the system supports future communications."
  }
];

const editorialPreviewImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Newsletter+Layout",
    alt: "Newsletter layout placeholder",
    caption: "Editorial work focused on hierarchy, readability, and institutional clarity."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Calendar+Agenda",
    alt: "Calendar and agenda placeholder",
    caption: "Recurring materials designed for usability, consistency, and practical communication."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Graduation+Program",
    alt: "Graduation program placeholder",
    caption: "Formal publication design for ceremonial and school-facing communications."
  }
];

const largeFormatPreviewImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Banner+Design",
    alt: "Banner design placeholder",
    caption: "Large-scale promotional graphics designed for visibility and brand presence."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Vinyl+Wrap",
    alt: "Vinyl wrap placeholder",
    caption: "Environmental graphics translating school identity into physical space."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=School+Signage",
    alt: "School signage placeholder",
    caption: "Large-format materials built for readability, scale, and real-world conditions."
  }
];
---

<BaseLayout
  title="Brittany Childs — Graphic Designer"
  description="Graphic designer specializing in brand systems, educational communications, publication design, and large-format visual materials."
>
  <Nav />

  <main>
    <section class="section hero-grid">
      <div class="reveal">
        <div class="eyebrow">Selected Work</div>
        <h1 class="display">Brittany Childs</h1>
        <p class="lead">
          Graphic Designer with 5 years of experience creating brand systems,
          editorial publications, and large-format communications for multiple school
          districts through CABOCES. Her work is grounded in clarity, consistency,
          and thoughtful design for institutional audiences.
        </p>
        <a class="button" href="/work">View Selected Work</a>
      </div>

      <div class="frame reveal">
        <img
          src="https://placehold.co/1600x1000/e9e1d7/1f1b18?text=Featured+Visual"
          alt="Featured portfolio visual"
        />
      </div>
    </section>

    <section class="section feature-grid">
      <div class="reveal">
        <div class="eyebrow">Featured Project</div>
        <h2 class="project-title" style="font-size: 2rem;">
          Jamestown Area Schools Brand Book
        </h2>
        <p class="lead">
          A comprehensive multi-school identity standards project developed to
          strengthen consistency across district communications while also creating
          CABOCES’ first formal process for brand-book development.
        </p>
        <a class="button" href="/work/jamestown-brand-book">View Case Study</a>
      </div>

      <div class="frame reveal">
        <img
          src="https://placehold.co/1600x1000/e9e1d7/1f1b18?text=Brand+Book+Preview"
          alt="Jamestown brand book preview"
        />
      </div>
    </section>

    <section class="section">
      <div class="eyebrow">Selected Work</div>
      <div class="grid-3">
        <article class="card reveal">
          <ImageCarousel images={jamestownPreviewImages} id="home-jamestown-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Brand Systems · 2026</div>
            <h3 class="project-title">Jamestown Area Schools Brand Book</h3>
            <p>
              A comprehensive multi-school identity system establishing structure,
              consistency, and a new internal workflow for brand standards development.
            </p>
            <a class="button" href="/work/jamestown-brand-book">View Case Study</a>
          </div>
        </article>

        <article class="card reveal">
          <ImageCarousel images={editorialPreviewImages} id="home-editorial-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Publications · 2025</div>
            <h3 class="project-title">Editorial & Publication Design</h3>
            <p>
              Newsletters, calendars, agendas, and graduation materials designed
              with emphasis on hierarchy, readability, and institutional consistency.
            </p>
            <a class="button" href="/work/editorial-publications">View Case Study</a>
          </div>
        </article>

        <article class="card reveal">
          <ImageCarousel images={largeFormatPreviewImages} id="home-large-format-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Environmental Design · 2025</div>
            <h3 class="project-title">Large-Format Graphics</h3>
            <p>
              Banners, signage, and vinyl graphics created for events, visibility,
              and branded school environments.
            </p>
            <a class="button" href="/work/large-format-signage">View Case Study</a>
          </div>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="process-strip reveal">
        <div>
          <strong>Multi-District Collaboration</strong>
          <p>
            Work developed across varied school stakeholders, audiences, and
            approval structures.
          </p>
        </div>
        <div>
          <strong>Brand Systems Development</strong>
          <p>
            Identity and standards work designed to support consistency over time.
          </p>
        </div>
        <div>
          <strong>Production-Aware Execution</strong>
          <p>
            Print and large-format design delivered with attention to scale,
            readability, and output quality.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <RevealScript />
</BaseLayout>