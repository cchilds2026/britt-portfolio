---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import RevealScript from "../components/RevealScript.astro";
---

<BaseLayout title="About — [Her Name]" description="About the designer">
  <Nav />

  <main>
    <section class="section about-grid">
      <div class="reveal">
        <div class="eyebrow">About</div>
        <h1 class="display" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">Design with clarity, system, and purpose.</h1>
        <p class="lead">
          [Her Name] is a graphic designer creating branded communications for
          multiple school districts through CABOCES. Her work includes brand
          systems, publication design, large-format graphics, and institutional
          materials designed for clear communication across diverse audiences.
        </p>
      </div>

      <div class="frame reveal">
        <img
          src="https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Portrait+or+Studio+Image"
          alt="Portrait placeholder"
        />
      </div>
    </section>
  </main>

  <Footer />
  <RevealScript />
</BaseLayout>