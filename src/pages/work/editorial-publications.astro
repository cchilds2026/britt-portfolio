---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import RevealScript from "../../components/RevealScript.astro";
import ImageCarousel from "../../components/ImageCarousel.astro";

const newsletterImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Newsletter+Layout+1",
    alt: "Newsletter layout placeholder",
    caption: "Newsletter layouts designed to organize district updates and school communication with clear hierarchy and readability."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Newsletter+Layout+2",
    alt: "Newsletter spread placeholder",
    caption: "Editorial structure built to support readability, pacing, and institutional clarity across recurring communications."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Newsletter+Layout+3",
    alt: "Newsletter detail placeholder",
    caption: "Layouts designed to feel organized, polished, and practical for school-facing audiences."
  }
];

const calendarImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Calendar+and+Agenda+1",
    alt: "Calendar and agenda placeholder",
    caption: "Calendars and agendas built for repeated use, with emphasis on usability, navigation, and durable visual systems."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Calendar+and+Agenda+2",
    alt: "Agenda spread placeholder",
    caption: "Structured page systems designed to support consistency across recurring institutional materials."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Calendar+and+Agenda+3",
    alt: "Calendar detail placeholder",
    caption: "Publication design balancing function, readability, and a cohesive school-facing presentation."
  }
];

const graduationImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Graduation+Program+1",
    alt: "Graduation program placeholder",
    caption: "Graduation programs designed as formal event materials aligned with school identity and institutional tone."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Graduation+Program+2",
    alt: "Graduation spread placeholder",
    caption: "Ceremonial print materials designed to feel organized, commemorative, and visually refined."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Graduation+Program+3",
    alt: "Graduation detail placeholder",
    caption: "Program layouts structured for clarity while preserving formality and institutional character."
  }
];
---

<BaseLayout
  title="Editorial & Publication Design — Brittany Childs"
  description="Case study covering newsletters, calendars, agendas, graduation programs, and institutional publication design."
>
  <Nav />

  <main>
    <section class="section editorial-page-intro">
      <div class="eyebrow">Publications</div>
      <h1 class="display" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
        Editorial & Publication Design
      </h1>
      <p class="lead">
        A collection of school communications materials designed to support
        clarity, hierarchy, consistency, and strong institutional presentation
        across recurring publications and high-visibility printed pieces.
      </p>
    </section>

    <section class="section editorial-hero-grid">
      <div class="frame reveal">
        <img
          src="https://placehold.co/1600x1000/e9e1d7/1f1b18?text=Editorial+Hero+Image"
          alt="Editorial and publication design overview"
        />
      </div>

      <div class="editorial-hero-copy reveal">
        <div class="editorial-hero-main">
          <h2 class="project-title" style="font-size: 2rem; margin-top: 0;">
            Publication systems built for readability and continuity.
          </h2>

          <p>
            This body of work focuses on recurring publications and institutional
            print materials that need to balance readability, structure, and
            visual consistency across multiple school audiences. Each piece is
            designed to support communication goals while maintaining an organized,
            polished presentation appropriate to educational settings.
          </p>
        </div>

        <div class="editorial-hero-meta">
          <div class="meta">Client: Multiple school districts through CABOCES</div>
          <div class="meta">Role: Design, layout, production preparation</div>
          <div class="meta">Scope: Newsletters, calendars, agendas, graduation programs</div>
        </div>
      </div>
    </section>

    <section class="section editorial-materials-section">
      <div class="eyebrow">Selected Materials</div>
      <div class="grid-3">
        <article class="card reveal">
          <ImageCarousel images={newsletterImages} id="editorial-newsletters-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Editorial Layout</div>
            <h3 class="project-title">Newsletters</h3>
            <p>
              Designed to organize district updates and school communication in
              a format that feels readable, structured, and visually coherent.
            </p>
          </div>
        </article>

        <article class="card reveal">
          <ImageCarousel images={calendarImages} id="editorial-calendars-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Institutional Materials</div>
            <h3 class="project-title">Calendars & Agendas</h3>
            <p>
              Built for repeated use, with emphasis on usability, navigation,
              consistency, and durable visual systems.
            </p>
          </div>
        </article>

        <article class="card reveal">
          <ImageCarousel images={graduationImages} id="editorial-graduation-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Ceremonial Print Design</div>
            <h3 class="project-title">Graduation Programs</h3>
            <p>
              Formal event materials designed to feel commemorative, organized,
              and visually aligned with school identity.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section class="section editorial-summary-section">
      <div class="editorial-summary reveal">
        <div>
          <div class="eyebrow">Approach</div>
          <h2 class="project-title" style="font-size: 1.9rem;">
            Designed for clarity, pacing, and institutional credibility.
          </h2>
        </div>

        <div>
          <p>
            Publication work in education often carries a dual responsibility:
            it must communicate clearly while also reinforcing trust, identity,
            and professionalism. These projects are approached with an editorial
            mindset that prioritizes legibility, hierarchy, and thoughtful pacing
            across multi-page formats.
          </p>
        </div>

        <div>
          <p>
            The result is work that feels usable, consistent, and visually
            disciplined across recurring school communications and formal
            institutional materials.
          </p>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top: 3rem;">
      <div class="eyebrow">Continue Exploring</div>
      <div class="case-nav-wrap reveal">
        <div class="case-nav">
          <a href="/work/jamestown-brand-book">
            <span class="label">Previous Project</span>
            <span class="title">Jamestown Area Schools Brand Book</span>
          </a>

          <a href="/work">
            <span class="label">All Work</span>
            <span class="title">Back to All Work</span>
          </a>

          <a href="/work/large-format-signage">
            <span class="label">Next Project</span>
            <span class="title">Large-Format Graphics</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <RevealScript />
</BaseLayout>