---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import RevealScript from "../../components/RevealScript.astro";
import ImageCarousel from "../../components/ImageCarousel.astro";

const coverImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Brand+Book+Cover+1",
    alt: "Brand book cover placeholder",
    caption: "Cover and opening presentation materials designed to establish the tone and structure of the Jamestown Area Schools brand book."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Brand+Book+Cover+2",
    alt: "Brand book cover variation placeholder",
    caption: "Brand book cover exploration showing the system’s institutional tone and visual consistency."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Brand+Book+Cover+3",
    alt: "Brand book cover detail placeholder",
    caption: "A structured opening section designed to feel clear, polished, and durable for long-term use."
  }
];

const standardsImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Standards+Spread+1",
    alt: "Standards spread placeholder",
    caption: "Interior standards pages organized to make brand guidance readable, navigable, and practical in use."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Standards+Spread+2",
    alt: "Standards system placeholder",
    caption: "System pages built around hierarchy, consistency, and a structure that supports real decision-making."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Standards+Spread+3",
    alt: "Standards detail placeholder",
    caption: "Guidelines developed to feel intuitive and scalable across multiple schools and future communications."
  }
];

const applicationImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Application+Examples+1",
    alt: "Application example placeholder",
    caption: "Application examples demonstrating how the brand standards system supports future communication consistency."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Application+Examples+2",
    alt: "Brand application variation placeholder",
    caption: "Examples showing how the system can extend across school-facing and district-facing materials."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Application+Examples+3",
    alt: "Brand application detail placeholder",
    caption: "Structured applications built to reinforce identity and maintain continuity over time."
  }
];
---

<BaseLayout
  title="Jamestown Area Schools Brand Book — Brittany Childs"
  description="Case study for the Jamestown Area Schools brand book and identity standards system."
>
  <Nav />

  <main>
    <section class="section editorial-page-intro">
      <div class="eyebrow">Brand Systems</div>
      <h1 class="display" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
        Jamestown Area Schools Brand Book
      </h1>
      <p class="lead">
        A comprehensive multi-school identity standards project developed to
        create greater consistency across district communications while also
        establishing CABOCES’ first formal workflow for brand-book development.
      </p>
    </section>

    <section class="section editorial-hero-grid">
      <div class="frame reveal">
        <img
          src="https://placehold.co/1600x1000/e9e1d7/1f1b18?text=Jamestown+Brand+Book+Hero"
          alt="Jamestown Area Schools brand book overview"
        />
      </div>

      <div class="editorial-hero-copy reveal">
        <div class="editorial-hero-main">
          <h2 class="project-title" style="font-size: 2rem; margin-top: 0;">
            A systems-driven brand standards project built from the ground up.
          </h2>

          <p>
            This project began as more than a design assignment. It required the
            development of an organized standards system for multiple schools,
            along with a clear internal process for how CABOCES approaches
            large-scale brand-book work moving forward. Because no established
            workflow existed, the project demanded both design execution and
            systems thinking from the ground up.
          </p>
        </div>

        <div class="editorial-hero-meta">
          <div class="meta">Client: Jamestown Area Schools</div>
          <div class="meta">Role: Graphic Design, Brand Systems Development</div>
          <div class="meta">Scope: Multi-school brand standards book</div>
          <div class="meta">Context: Educational communications / institutional identity</div>
        </div>
      </div>
    </section>

    <section class="section editorial-materials-section">
      <div class="eyebrow">Selected Materials</div>
      <div class="grid-3">
        <article class="card reveal">
          <ImageCarousel images={coverImages} id="jamestown-cover-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Core Deliverable</div>
            <h3 class="project-title">Brand Book Framework</h3>
            <p>
              A structured standards document designed to guide identity use and
              future communications across a multi-school environment.
            </p>
          </div>
        </article>

        <article class="card reveal">
          <ImageCarousel images={standardsImages} id="jamestown-standards-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Standards Development</div>
            <h3 class="project-title">System Guidelines</h3>
            <p>
              Pages focused on organizing identity guidance into a form that is
              clear, readable, and useful in practice.
            </p>
          </div>
        </article>

        <article class="card reveal">
          <ImageCarousel images={applicationImages} id="jamestown-applications-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Future Application</div>
            <h3 class="project-title">Communication Alignment</h3>
            <p>
              The system was built to support stronger consistency across future
              district and school-facing materials.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section class="section editorial-summary-section">
      <div class="editorial-summary reveal">
        <div>
          <div class="eyebrow">Approach</div>
          <h2 class="project-title" style="font-size: 1.9rem;">
            Built for structure, stewardship, and long-term institutional use.
          </h2>
        </div>

        <div>
          <p>
            Jamestown Area Schools needed a framework that could support
            multiple schools and identities while still feeling coherent as part
            of a larger district environment. The work focused on building a
            standards document that could operate as a true system rather than
            simply a visual reference.
          </p>
        </div>

        <div>
          <p>
            The result is a flagship systems project that reflects a more
            strategic mode of communication design—one focused on consistency,
            clarity, scalability, and long-term value.
          </p>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top: 3rem;">
      <div class="eyebrow">Continue Exploring</div>
      <div class="case-nav-wrap reveal">
        <div class="case-nav">
          <a href="/work/large-format-signage">
            <span class="label">Previous Project</span>
            <span class="title">Large-Format Graphics</span>
          </a>

          <a href="/work">
            <span class="label">All Work</span>
            <span class="title">Back to All Work</span>
          </a>

          <a href="/work/editorial-publications">
            <span class="label">Next Project</span>
            <span class="title">Editorial & Publication Design</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <RevealScript />
</BaseLayout>