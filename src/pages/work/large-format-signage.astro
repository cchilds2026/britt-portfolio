---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import RevealScript from "../../components/RevealScript.astro";
---

<BaseLayout
  title="Large-Format Graphics — [Her Name]"
  description="Case study covering banners, vinyl wraps, signage, and large-format graphics for schools and institutional environments."
>
  <Nav />

  <main>
    <section class="section">
      <div class="eyebrow">Environmental Design</div>
      <h1 class="display" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
        Large-Format Graphics
      </h1>
      <p class="lead">
        Large-scale visual materials created for school environments, events,
        and public-facing communications, with emphasis on visibility, brand
        consistency, and production-aware execution.
      </p>
    </section>

    <section class="section feature-grid">
      <div class="reveal">
        <div class="meta">Client: Multiple school districts through CABOCES</div>
        <div class="meta">Role: Design, file preparation, production support</div>
        <div class="meta">Scope: Banners, signage, vinyl wraps, event graphics</div>
      </div>

      <div class="frame reveal">
        <img
          src="https://placehold.co/1600x1000/e9e1d7/1f1b18?text=Large+Format+Hero+Image"
          alt="Large-format graphics overview"
        />
      </div>
    </section>

    <section class="section about-grid">
      <div class="reveal">
        <h2 class="project-title">Overview</h2>
        <p>
          This work includes large-format communication pieces designed to
          perform at scale across school campuses, events, and community-facing
          environments. Projects range from promotional banners to vinyl wraps
          and signage systems that extend institutional identity into physical
          space.
        </p>
      </div>

      <div class="reveal">
        <h2 class="project-title">Production Awareness</h2>
        <p>
          Large-format design requires more than visual impact. It also depends
          on strong production judgment, careful attention to scale, legibility
          at distance, output requirements, and collaboration with print
          production workflows to ensure successful final execution.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="eyebrow">Selected Materials</div>
      <div class="grid-3">
        <div class="card reveal">
          <div class="frame">
            <img
              src="https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Banners"
              alt="Banner design placeholder"
            />
          </div>
          <div class="card-body">
            <div class="meta">Promotional Graphics</div>
            <h3 class="project-title">Banners</h3>
            <p>
              Event and promotional materials designed for strong readability,
              visual presence, and brand consistency in public settings.
            </p>
          </div>
        </div>

        <div class="card reveal">
          <div class="frame">
            <img
              src="https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Vinyl+Wraps"
              alt="Vinyl wrap placeholder"
            />
          </div>
          <div class="card-body">
            <div class="meta">Environmental Branding</div>
            <h3 class="project-title">Vinyl Wraps</h3>
            <p>
              Large-scale applications that translate identity and messaging
              onto surfaces with attention to impact, scale, and production
              accuracy.
            </p>
          </div>
        </div>

        <div class="card reveal">
          <div class="frame">
            <img
              src="https://placehold.co/1200x1500/e9e1d7/1f1b18?text=School+Signage"
              alt="School signage placeholder"
            />
          </div>
          <div class="card-body">
            <div class="meta">Wayfinding & Visibility</div>
            <h3 class="project-title">Signage</h3>
            <p>
              School-facing graphics that support visibility, communication, and
              branded presence across institutional environments.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section feature-grid">
      <div class="frame reveal">
        <img
          src="https://placehold.co/1600x1000/e9e1d7/1f1b18?text=Large+Format+Installed+View"
          alt="Installed large-format graphic placeholder"
        />
      </div>

      <div class="reveal">
        <div class="eyebrow">Approach</div>
        <h2 class="project-title" style="font-size: 2rem;">
          Built for visibility, scale, and real-world conditions.
        </h2>
        <p>
          Unlike smaller print pieces, large-format work has to succeed in
          physical space. That means designing for distance, environment,
          material constraints, and the realities of production. The goal is to
          create work that is visually strong, clearly legible, and dependable
          from concept through final installation.
        </p>
      </div>
    </section>
  </main>

  <Footer />
  <RevealScript />
</BaseLayout>