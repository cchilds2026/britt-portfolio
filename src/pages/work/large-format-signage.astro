---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import RevealScript from "../../components/RevealScript.astro";
import ImageCarousel from "../../components/ImageCarousel.astro";

const bannerImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Banner+Design+1",
    alt: "Banner design placeholder",
    caption: "Event and promotional banner graphics designed for strong readability, visual presence, and brand consistency."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Banner+Design+2",
    alt: "Banner variation placeholder",
    caption: "Large-scale promotional materials built to succeed in public-facing school environments."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Banner+Design+3",
    alt: "Banner detail placeholder",
    caption: "Work designed to remain clear, legible, and visually effective at scale."
  }
];

const vinylWrapImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Vinyl+Wrap+1",
    alt: "Vinyl wrap placeholder",
    caption: "Environmental branding applied to surfaces with attention to scale, messaging, and installation impact."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Vinyl+Wrap+2",
    alt: "Vinyl wrap application placeholder",
    caption: "Identity translated into physical space through large-scale graphic applications."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=Vinyl+Wrap+3",
    alt: "Vinyl wrap detail placeholder",
    caption: "Production-aware large-format work shaped by environment, material constraints, and visibility goals."
  }
];

const signageImages = [
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=School+Signage+1",
    alt: "School signage placeholder",
    caption: "Signage designed to support visibility, communication, and branded presence across institutional environments."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=School+Signage+2",
    alt: "Wayfinding signage placeholder",
    caption: "School-facing graphics built for readability, function, and consistency in real-world conditions."
  },
  {
    src: "https://placehold.co/1200x1500/e9e1d7/1f1b18?text=School+Signage+3",
    alt: "Signage detail placeholder",
    caption: "Large-format communication pieces designed for both clarity and visual impact."
  }
];
---

<BaseLayout
  title="Large-Format Graphics — Brittany Childs"
  description="Case study covering banners, vinyl wraps, signage, and large-format graphics for schools and institutional environments."
>
  <Nav />

  <main>
    <section class="section editorial-page-intro">
      <div class="eyebrow">Environmental Design</div>
      <h1 class="display" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
        Large-Format Graphics
      </h1>
      <p class="lead">
        Large-scale visual materials created for school environments, events,
        and public-facing communications, with emphasis on visibility, brand
        consistency, and production-aware execution.
      </p>
    </section>

    <section class="section editorial-hero-grid">
      <div class="frame reveal">
        <img
          src="https://placehold.co/1600x1000/e9e1d7/1f1b18?text=Large+Format+Hero+Image"
          alt="Large-format graphics overview"
        />
      </div>

      <div class="editorial-hero-copy reveal">
        <div class="editorial-hero-main">
          <h2 class="project-title" style="font-size: 2rem; margin-top: 0;">
            Large-format work built for visibility, scale, and real-world conditions.
          </h2>

          <p>
            This work includes large-format communication pieces designed to
            perform across school campuses, events, and community-facing
            environments. Projects range from promotional banners to vinyl wraps
            and signage systems that extend institutional identity into physical
            space while accounting for production realities, readability, and
            environmental context.
          </p>
        </div>

        <div class="editorial-hero-meta">
          <div class="meta">Client: Multiple school districts through CABOCES</div>
          <div class="meta">Role: Design, file preparation, production support</div>
          <div class="meta">Scope: Banners, signage, vinyl wraps, event graphics</div>
        </div>
      </div>
    </section>

    <section class="section editorial-materials-section">
      <div class="eyebrow">Selected Materials</div>
      <div class="grid-3">
        <article class="card reveal">
          <ImageCarousel images={bannerImages} id="largeformat-banners-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Promotional Graphics</div>
            <h3 class="project-title">Banners</h3>
            <p>
              Event and promotional materials designed for strong readability,
              visual presence, and brand consistency in public settings.
            </p>
          </div>
        </article>

        <article class="card reveal">
          <ImageCarousel images={vinylWrapImages} id="largeformat-wraps-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Environmental Branding</div>
            <h3 class="project-title">Vinyl Wraps</h3>
            <p>
              Large-scale applications that translate identity and messaging
              onto surfaces with attention to impact, scale, and production
              accuracy.
            </p>
          </div>
        </article>

        <article class="card reveal">
          <ImageCarousel images={signageImages} id="largeformat-signage-preview" mode="lightboxOnly" />
          <div class="card-body">
            <div class="meta">Wayfinding & Visibility</div>
            <h3 class="project-title">Signage</h3>
            <p>
              School-facing graphics that support visibility, communication, and
              branded presence across institutional environments.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section class="section editorial-summary-section">
      <div class="editorial-summary reveal">
        <div>
          <div class="eyebrow">Approach</div>
          <h2 class="project-title" style="font-size: 1.9rem;">
            Designed with scale, environment, and installation in mind.
          </h2>
        </div>

        <div>
          <p>
            Unlike smaller print pieces, large-format work has to succeed in
            physical space. That means designing for distance, environment,
            material constraints, and the realities of production. The work must
            remain strong both visually and functionally once it leaves the
            screen and becomes part of a real setting.
          </p>
        </div>

        <div>
          <p>
            The result is work that feels bold, clear, and dependable from
            concept through final output, while reinforcing brand presence in
            visible public and institutional environments.
          </p>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top: 3rem;">
      <div class="eyebrow">Continue Exploring</div>
      <div class="case-nav-wrap reveal">
        <div class="case-nav">
          <a href="/work/editorial-publications">
            <span class="label">Previous Project</span>
            <span class="title">Editorial & Publication Design</span>
          </a>

          <a href="/work">
            <span class="label">All Work</span>
            <span class="title">Back to All Work</span>
          </a>

          <a href="/work/jamestown-brand-book">
            <span class="label">Next Project</span>
            <span class="title">Jamestown Area Schools Brand Book</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <RevealScript />
</BaseLayout>